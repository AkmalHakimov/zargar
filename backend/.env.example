APP_NAME=Zargar Labs
DATABASE_URL=sqlite:///./zargar_demo.db
USE_MOCK_LLM=true
LLM_PROVIDER=mock
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
EMBEDDING_PROVIDER=hash
EMBEDDING_DIMENSIONS=1536
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_IDS=
TELEGRAM_ALLOWED_CHAT_IDS=
GITHUB_TOKEN=
GITHUB_ALLOWED_REPOS=
GITHUB_DRAFT_PRS_ONLY=true
GITHUB_MAX_FILES_CHANGED=5
GITHUB_MAX_LINES_CHANGED=300
GITHUB_MAX_NEW_FILES=3
BRANCH_RETENTION_DAYS=7
DEVELOPER_AGENT_MODE=plan_only
DEVELOPER_CODING_ENGINE=deterministic
CODEX_CLI_PATH=codex
DEVELOPER_COMPLEX_MIN_SOURCE_FILES=2
DEVELOPER_COMPLEX_MIN_SOURCE_LINES=20
DEVELOPER_FRONTEND_COMPLEX_MIN_SOURCE_FILES=2
DEVELOPER_MULTIPAGE_MIN_RELEVANT_SOURCE_FILES=2
MAX_CHANGED_FILES_FOR_MVP=30
MAX_CHANGED_SOURCE_LINES_FOR_MVP=2500
MAX_ALLOWED_DIRECTORIES_FOR_MVP=8
ALLOW_COMPLEX_REPO_TASKS=true
